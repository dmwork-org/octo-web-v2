# Vite 暴露给客户端的环境变量必须以 VITE_ 前缀。
# 本文件作为约定模板提交,真实值放在 .env.local / .env.development.local(被 .gitignore 忽略)

# ofetch baseURL — 后端 API 前缀,必须跟 vite.config.ts server.proxy 配的前缀一致。
# 老仓后端契约是 /v1,推荐就用 /v1。如果历史 .env.local 设了 /api 也兼容
# (vite proxy 加了 /api → /v1 rewrite 兜底)。
VITE_API_BASE_URL=/v1

# Dev server proxy target(对应 vite.config.ts server.proxy):
# /v1, /matter/api/v1, /summary/api/v1 三路前缀的请求都会被代理到这里。
# 仅 `pnpm dev` 生效;生产构建出来的静态文件不带 proxy,生产环境由部署网关路由。
# **必填**:不设会让 vite dev 启动直接抛错(避免无声 fallback 到错误目标)。
# 默认假设本地后端监听 8080;测试/staging 改自己的 host。
VITE_API_URL=http://localhost:8080

# 可选管理后台 base URL。为空时隐藏空间管理跳转。
VITE_ADMIN_URL=

# 企业 SSO 开关(对齐老仓 dmworklogin VITE_ENABLE_ENTERPRISE_SSO):
# - "true":登录页接 SSO 主路径(走 OIDC IdP);
#   appconfig.oidc_providers 必须非空才会显示主 CTA;
#   legacy_password_login_off=1 时进一步隐藏本地密码表单
# - 其他值(含未设):仅显本地用户名密码登录,SSO 入口完全不渲染
#   (即使 appconfig.oidc_providers 有值也忽略)
VITE_ENABLE_ENTERPRISE_SSO=false
