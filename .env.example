# Vite 暴露给客户端的环境变量必须以 VITE_ 前缀。
# 本文件作为约定模板提交,真实值放在 .env.local / .env.development.local(被 .gitignore 忽略)

# ofetch baseURL — 默认走相对路径 /api,部署时按需改
VITE_API_BASE_URL=/api

# 企业 SSO 开关(对齐老仓 dmworklogin VITE_ENABLE_ENTERPRISE_SSO):
# - "true":登录页接 SSO 主路径(走 OIDC IdP);
#   appconfig.oidc_providers 必须非空才会显示主 CTA;
#   legacy_password_login_off=1 时进一步隐藏本地密码表单
# - 其他值(含未设):仅显本地用户名密码登录,SSO 入口完全不渲染
#   (即使 appconfig.oidc_providers 有值也忽略)
VITE_ENABLE_ENTERPRISE_SSO=false
